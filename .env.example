# Optional override for local Career Agent data storage.
# If unset, the app defaults to a ".career-agent" directory under your user home.
#
# Portable user-home example:
# CAREER_AGENT_DATA_DIR=~/.career-agent
#
# Windows absolute path example:
# CAREER_AGENT_DATA_DIR=C:/Users/ExampleUser/.career-agent

# Optional OpenAI-compatible LLM endpoint configuration.
# If CAREER_AGENT_LLM_BASE_URL is unset, supported workflows use deterministic
# local behavior and make no LLM network calls. If it is set, supported workflows
# use the OpenAI-compatible LLM client and require CAREER_AGENT_LLM_MODEL or a
# workflow-specific model override.
#
# Local endpoint example:
# CAREER_AGENT_LLM_BASE_URL=http://localhost:1234/v1
# CAREER_AGENT_LLM_API_KEY=not-needed-for-local
# CAREER_AGENT_LLM_MODEL=qwen36
#
# Optional role-specific overrides.
# If unset, these fall back to CAREER_AGENT_LLM_BASE_URL, CAREER_AGENT_LLM_API_KEY,
# and CAREER_AGENT_LLM_MODEL.
# CAREER_AGENT_LLM_EXTRACTION_BASE_URL=http://localhost:1234/v1
# CAREER_AGENT_LLM_EXTRACTION_API_KEY=not-needed-for-local
# CAREER_AGENT_LLM_EXTRACTION_MODEL=gemma4-doc
# CAREER_AGENT_LLM_EVAL_BASE_URL=http://localhost:1234/v1
# CAREER_AGENT_LLM_EVAL_API_KEY=not-needed-for-local
# CAREER_AGENT_LLM_EVAL_MODEL=mistral-small-4-review
#
# Hosted OpenAI-compatible endpoint example:
# CAREER_AGENT_LLM_BASE_URL=https://api.openai.com/v1
# CAREER_AGENT_LLM_API_KEY=replace-with-your-api-key
# CAREER_AGENT_LLM_MODEL=gpt-4.1-mini
